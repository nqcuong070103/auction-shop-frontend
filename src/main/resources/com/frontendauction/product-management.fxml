<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<AnchorPane prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: #f4f6f8;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shop.controller.ProductManagementController">
    <children>
        <SplitPane dividerPositions="0.55"
                   style="-fx-background-color: transparent; -fx-padding: 30;"
                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <AnchorPane minHeight="0.0" minWidth="0.0">
                    <children>
                        <VBox style="-fx-background-color: white;
                                    -fx-background-radius: 14;
                                    -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 14, 0, 0, 5);"
                              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                              AnchorPane.rightAnchor="16.0" AnchorPane.topAnchor="0.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                            </padding>
                            <children>
                                <Label alignment="CENTER" prefHeight="50.0"
                                       prefWidth="900.0"
                                       text="Danh sách sản phẩm của bạn">
                                    <font>
                                        <Font name="System Bold" size="42.0"/>
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="18.0" left="10.0" top="10.0"/>
                                    </VBox.margin>
                                </Label>
                                <TableView fx:id="tvProducts"
                                           style="-fx-font-size: 20px;"
                                           VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn id="colId"
                                                     prefWidth="100.0"
                                                     style="-fx-alignment: CENTER;"
                                                     text="ID"/>
                                        <TableColumn id="colName"
                                                     prefWidth="360.0"
                                                     text="Tên sản phẩm"/>
                                        <TableColumn id="colPrice"
                                                     prefWidth="220.0"
                                                     style="-fx-alignment: CENTER-RIGHT;"
                                                     text="Giá khởi điểm"/>
                                        <TableColumn id="colDescription"
                                                     prefWidth="320.0"
                                                     text="Mô tả"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
                <AnchorPane minHeight="0.0" minWidth="0.0">
                    <children>
                        <VBox alignment="TOP_CENTER" spacing="36.0"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 14;
                                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 14, 0, 0, 5);"
                              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="16.0"
                              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <children>
                                <Label text="Chi tiết sản phẩm" textFill="#2c3e50">
                                    <font>
                                        <Font name="System Bold" size="38.0"/>
                                    </font>
                                </Label>
                                <GridPane hgap="20.0" vgap="28.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES"
                                                           maxWidth="220.0"
                                                           minWidth="10.0"
                                                           prefWidth="190.0"/>
                                        <ColumnConstraints hgrow="ALWAYS"
                                                           minWidth="10.0"
                                                           prefWidth="420.0"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="65.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="65.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="65.0" vgrow="SOMETIMES"/>
                                        <RowConstraints minHeight="10.0" prefHeight="160.0" vgrow="SOMETIMES"/>
                                    </rowConstraints>
                                    <children>
                                        <Label text="Mã ID:" textFill="#7f8c8d">
                                            <font>
                                                <Font name="System Bold" size="22.0"/>
                                            </font>
                                        </Label>
                                        <Label text="Tên sản phẩm:" textFill="#7f8c8d"
                                               GridPane.rowIndex="1">
                                            <font>
                                                <Font name="System Bold" size="22.0"/>
                                            </font>
                                        </Label>
                                        <Label text="Giá khởi điểm:" textFill="#7f8c8d"
                                               GridPane.rowIndex="2">
                                            <font>
                                                <Font name="System Bold" size="22.0"/>
                                            </font>
                                        </Label>
                                        <Label text="Mô tả:" textFill="#7f8c8d"
                                               GridPane.rowIndex="3" GridPane.valignment="TOP">
                                            <font>
                                                <Font name="System Bold" size="22.0"/>
                                            </font>
                                            <GridPane.margin>
                                                <Insets top="14.0"/>
                                            </GridPane.margin>
                                        </Label>
                                        <TextField fx:id="txtId" disable="true"
                                                   promptText="(Tạo tự động)"
                                                   style="-fx-background-radius: 8; -fx-pref-height: 58; -fx-font-size: 20px;"
                                                   GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtName"
                                                   style="-fx-background-radius: 8; -fx-pref-height: 58; -fx-font-size: 20px;"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtPrice"
                                                   style="-fx-background-radius: 8; -fx-pref-height: 58; -fx-font-size: 20px;"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                        <TextArea fx:id="txtDescription"
                                                  prefHeight="150.0" prefWidth="420.0"
                                                  promptText="Nhập thông tin chi tiết về tình trạng sản phẩm..."
                                                  style="-fx-background-radius: 8; -fx-font-size: 20px;"
                                                  wrapText="true"
                                                  GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                    </children>
                                </GridPane>
                                <HBox alignment="CENTER" spacing="20.0">
                                    <children>
                                        <Button fx:id="btnAdd" mnemonicParsing="false"
                                                prefHeight="62.0" prefWidth="160.0"
                                                style="-fx-background-color: #2ecc71;
                                                       -fx-text-fill: white;
                                                       -fx-font-weight: bold;
                                                       -fx-background-radius: 8;
                                                       -fx-font-size: 20px;
                                                       -fx-cursor: hand;"
                                                text="Thêm Mới"/>
                                        <Button fx:id="btnUpdate" mnemonicParsing="false"
                                                prefHeight="62.0" prefWidth="160.0"
                                                style="-fx-background-color: #f39c12;
                                                       -fx-text-fill: white;
                                                       -fx-font-weight: bold;
                                                       -fx-background-radius: 8;
                                                       -fx-font-size: 20px;
                                                       -fx-cursor: hand;"
                                                text="Cập Nhật"/>
                                        <Button fx:id="btnDelete" mnemonicParsing="false"
                                                prefHeight="62.0" prefWidth="160.0"
                                                style="-fx-background-color: #e74c3c;
                                                       -fx-text-fill: white;
                                                       -fx-font-weight: bold;
                                                       -fx-background-radius: 8;
                                                       -fx-font-size: 20px;
                                                       -fx-cursor: hand;"
                                                text="Xóa"/>
                                    </children>
                                    <VBox.margin>
                                        <Insets top="20.0"/>
                                    </VBox.margin>
                                </HBox>

                            </children>
                            <padding>
                                <Insets bottom="50.0" left="40.0" right="40.0" top="50.0"/>
                            </padding>
                        </VBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
