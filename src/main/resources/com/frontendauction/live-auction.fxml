<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shop.controller.BiddingController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

         <center>
            <VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" BorderPane.alignment="CENTER">
               <BorderPane.margin>
                  <Insets bottom="10.0" left="20.0" right="10.0" top="20.0" />
               </BorderPane.margin>
               <padding>
                  <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
               </padding>
               <children>
                  <Label fx:id="lblProductName" text="Tên Sản Phẩm" wrapText="true">
                     <font>
                        <Font name="System Bold" size="30.0" />
                     </font>
                  </Label>
                  <Label fx:id="lblSeller" text="Người bán: Đang tải..." textFill="#7f8c8d">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <ImageView fx:id="imgProduct" fitHeight="180.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true" />

                  <!-- PHẦN MÔ TẢ ĐÃ ĐƯỢC NÂNG CẤP CHIỀU DÀI -->
                  <ScrollPane fitToWidth="true" minHeight="120.0" prefHeight="150.0" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: #ecf0f1; -fx-border-radius: 8;">
                     <content>
                        <Label fx:id="lblDescription" alignment="TOP_LEFT" text="Mô tả chi tiết sản phẩm" textFill="#555555" wrapText="true">
                           <font>
                              <Font size="13.0" />
                           </font>
                           <padding>
                              <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                           </padding>
                        </Label>
                     </content>
                  </ScrollPane>

                  <Label text="Giá cao nhất hiện tại:" textFill="#7f8c8d">
                     <font><Font size="14.0" /></font>
                     <VBox.margin><Insets top="5.0" /></VBox.margin>
                  </Label>
                  <Label fx:id="lblCurrentPrice" text="0 VNĐ" textFill="#e74c3c">
                     <font><Font name="System Bold" size="36.0" /></font>
                  </Label>
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label text="⏱ Thời gian còn lại:" textFill="#f39c12">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label fx:id="lblTimeLeft" text="00:00:00" textFill="#e67e22">
                           <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </center>

         <bottom>
            <HBox alignment="CENTER" prefHeight="80.0" spacing="15.0" BorderPane.alignment="CENTER">
               <children>
                  <TextField fx:id="txtBidAmount" prefHeight="45.0" prefWidth="250.0" promptText="Nhập số tiền muốn đặt giá" style="-fx-background-radius: 25; -fx-padding: 0 15 0 15; -fx-font-size: 14px;" />
                  <Button fx:id="btnPlaceBid" mnemonicParsing="false" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Đặt Giá" />
               </children>
            </HBox>
         </bottom>

         <right>
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" BorderPane.alignment="CENTER">
               <BorderPane.margin>
                  <Insets bottom="10.0" left="10.0" right="20.0" top="20.0" />
               </BorderPane.margin>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="15.0" />
               </padding>
               <children>
                  <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="📜 Lịch sử đấu giá" textFill="#34495e">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
                  <ListView fx:id="lvBidHistory" prefHeight="350.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-border-color: #ecf0f1; -fx-border-radius: 5;" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </right>
      </BorderPane>
   </children>
</AnchorPane>
