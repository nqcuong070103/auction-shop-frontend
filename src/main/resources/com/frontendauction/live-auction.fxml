<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<AnchorPane prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: #f4f6f8;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shop.controller.LiveAuctionController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <center>
                <VBox alignment="CENTER" spacing="24.0"
                      style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 18, 0, 0, 8);"
                      BorderPane.alignment="CENTER">
                    <BorderPane.margin>
                        <Insets bottom="20.0" left="40.0" right="20.0" top="40.0"/>
                    </BorderPane.margin>
                    <padding>
                        <Insets bottom="40.0" left="50.0" right="50.0" top="40.0"/>
                    </padding>
                    <children>
                        <Label fx:id="lblProductName" text="Tên Sản Phẩm" wrapText="true">
                            <font>
                                <Font name="System Bold" size="54.0"/>
                            </font>
                        </Label>
                        <Label fx:id="lblSeller" text="Người bán: Đang tải..." textFill="#7f8c8d">
                            <font>
                                <Font size="26.0"/>
                            </font>
                        </Label>
                        <ImageView fx:id="imgProduct"
                                   fitHeight="340.0" fitWidth="480.0"
                                   pickOnBounds="true" preserveRatio="true"/>
                        <ScrollPane fitToWidth="true"
                                    minHeight="220.0" prefHeight="280.0"
                                    style="-fx-background-color: transparent;
                                     -fx-background: transparent;
                                     -fx-border-color: #ecf0f1;
                                     -fx-border-radius: 10;">
                            <content>
                                <Label fx:id="lblDescription" alignment="TOP_LEFT"
                                       text="Mô tả chi tiết sản phẩm"
                                       textFill="#555555" wrapText="true">
                                    <font>
                                        <Font size="22.0"/>
                                    </font>
                                    <padding>
                                        <Insets bottom="16.0" left="18.0" right="18.0" top="16.0"/>
                                    </padding>
                                </Label>
                            </content>
                        </ScrollPane>
                        <Label text="Giá cao nhất hiện tại:" textFill="#7f8c8d">
                            <font>
                                <Font size="26.0"/>
                            </font>
                            <VBox.margin>
                                <Insets top="10.0"/>
                            </VBox.margin>
                        </Label>
                        <Label fx:id="lblCurrentPrice" text="0 VNĐ" textFill="#e74c3c">
                            <font>
                                <Font name="System Bold" size="68.0"/>
                            </font>
                        </Label>
                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Label text="⏱ Thời gian còn lại:" textFill="#f39c12">
                                    <font>
                                        <Font name="System Bold" size="28.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="lblTimeLeft" text="00:00:00" textFill="#e67e22">
                                    <font>
                                        <Font name="System Bold" size="28.0"/>
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </center>
            <bottom>
                <HBox alignment="CENTER" prefHeight="130.0" spacing="30.0"
                      BorderPane.alignment="CENTER">
                    <children>
                        <TextField fx:id="txtBidAmount"
                                   prefHeight="70.0" prefWidth="500.0"
                                   promptText="Nhập số tiền muốn đặt giá"
                                   style="-fx-background-radius: 35;
                                    -fx-padding: 0 28 0 28;
                                    -fx-font-size: 22px;"/>
                        <Button fx:id="btnPlaceBid" mnemonicParsing="false"
                                prefHeight="70.0" prefWidth="200.0"
                                style="-fx-background-color: #3498db;
                                 -fx-text-fill: white;
                                 -fx-background-radius: 35;
                                 -fx-font-weight: bold;
                                 -fx-font-size: 22px;
                                 -fx-cursor: hand;"
                                text="Đặt Giá"/>
                    </children>
                </HBox>
            </bottom>
            <right>
                <VBox spacing="20.0"
                      style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 18, 0, 0, 8);"
                      BorderPane.alignment="CENTER">
                    <BorderPane.margin>
                        <Insets bottom="20.0" left="20.0" right="40.0" top="40.0"/>
                    </BorderPane.margin>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="28.0"/>
                    </padding>
                    <children>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308"
                               text="📜 Lịch sử đấu giá" textFill="#34495e">
                            <font>
                                <Font name="System Bold" size="28.0"/>
                            </font>
                        </Label>
                        <ListView fx:id="lvBidHistory"
                                  prefHeight="700.0" prefWidth="440.0"
                                  style="-fx-background-color: transparent;
                                   -fx-border-color: #ecf0f1;
                                   -fx-border-radius: 8;
                                   -fx-font-size: 20px;"
                                  VBox.vgrow="ALWAYS"/>
                    </children>
                </VBox>
            </right>
        </BorderPane>
    </children>
</AnchorPane>
